<stringAttribute key="ilg.gnumcueclipse.debug.gdbjtag.openocd.gdbServerOther" value="-s &quot;${openocd_path}/../scripts&quot;&#13;&#10;-s &quot;../bsps/TARGET_APP_KIT_PSE84_EVAL_EPC2/config/GeneratedSource&quot;&#13;&#10;-c &quot;set QSPI_FLASHLOADER ../bsps/TARGET_APP_KIT_PSE84_EVAL_EPC2/config/GeneratedSource/PSE84_SMIF.FLM&quot;&#13;&#10;-c &quot;set DEBUG_CERTIFICATE ../packets/debug_token.bin&quot;&#13;&#10;-c &quot;source [find interface/kitprog3.cfg]&quot;&#13;&#10;-c &quot;transport select swd&quot;&#13;&#10;-c &quot;puts stderr {Started by GNU MCU Eclipse}&quot;&#13;&#10;-c &quot;set ENABLE_CM55 1&quot;&#13;&#10;-c &quot;gdb_port 3332&quot;&#13;&#10;-c &quot;source [find target/infineon/pse84xgxs2.cfg]&quot;&#13;&#10;-c &quot;cat1d.cm55 configure -rtos auto -rtos-wipe-on-reset-halt 1&quot;&#13;&#10;-c &quot;gdb_breakpoint_override hard&quot;&#13;&#10;-c &quot;init; reset init;adapter speed 12000; flash write_image erase ${workspace_loc:/le-audio}/proj_cm55/build/last_config/proj_cm55.hex;&quot;&#13;&#10;-c &quot;reset init;&quot;"/>
<intAttribute key="ilg.gnumcueclipse.debug.gdbjtag.openocd.gdbServerTelnetPortNumber" value="4444"/>

# Build outputs
build/
Debug/
Release/
*.o
*.obj
*.elf
*.hex
*.bin
*.map
*.lst

# ModusToolbox
mtb_shared/
mtb/mtb_shared/
mtb/le-audio/build/
mtb/le-audio/proj_*/build/
GeneratedSource/
*.mtbproj
*.mtbsearch
.modustoolbox
.mtbqueryapi
.ninja_log

# MTB libs folders - ignore downloaded libraries but keep .mtb and .mk files
mtb/le-audio/proj_*/libs/*/
!mtb/le-audio/proj_*/libs/*.mtb
!mtb/le-audio/proj_*/libs/*.mk

# IDE files
.vscode/
.idea/
*.suo
*.user
*.sln
*.vcxproj*

# Eclipse
.project
.cproject
.settings/

# Logs and temporary files
*.log
*.tmp
*.bak
*.swp
*~

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Python
__pycache__/
*.py[cod]
venv/
.env

# Dependencies are added as git submodules
# See: git submodule update --init --recursive

# Keep directory structure
!source/audio/.gitkeep
!source/le_audio/.gitkeep
!source/midi/.gitkeep
!source/bluetooth/.gitkeep
!config/.gitkeep
!libs/.gitkeep
!docs/.gitkeep
